{
  "name": "sympho",
  "version": "0.1.0",
  "description": "Autonomous agent orchestrator inspired by OpenAI Symphony — polls issue trackers, dispatches coding agents in isolated workspaces",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sympho": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["agent", "orchestrator", "ai", "claude", "automation"],
  "license": "Apache-2.0",
  "dependencies": {
    "liquidjs": "^10.21.0",
    "pino": "^9.6.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
